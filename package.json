{
  "name": "brdg",
  "private": true,
  "scripts": {
    "check": "npm run check:backend && npm run check:mobile",
    "check:backend": "npm --prefix backend run check",
    "check:mobile": "npm --prefix mobile run check",
    "smoke": "./scripts/smoke-e2e.sh",
    "storybook": "npm --prefix mobile run storybook:start",
    "dev:backend": "npm --prefix backend run start:dev",
    "dev:mobile": "npm --prefix mobile run start",
    "dev:scenario": "npm --prefix backend run dev:scenario --",
    "release:ios": "./scripts/release-ios.sh --mode xcode",
    "release:ios:check": "./scripts/release-ios.sh --check-only --mode xcode",
    "test:backend": "npm --prefix backend run test",
    "test:mobile": "npm --prefix mobile run test"
  }
}
