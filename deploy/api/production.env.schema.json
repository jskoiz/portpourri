{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BRDG backend production runtime env",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "NODE_ENV",
    "PORT",
    "POSTGRES_USER",
    "POSTGRES_PASSWORD",
    "POSTGRES_DB",
    "DATABASE_URL",
    "JWT_SECRET",
    "API_IMAGE",
    "BASE_URL",
    "API_BASE_URL",
    "ALLOWED_ORIGINS"
  ],
  "properties": {
    "NODE_ENV": {
      "type": "string",
      "const": "production"
    },
    "PORT": {
      "type": "string",
      "pattern": "^[0-9]{2,5}$"
    },
    "POSTGRES_USER": {
      "type": "string",
      "minLength": 1
    },
    "POSTGRES_PASSWORD": {
      "type": "string",
      "minLength": 1,
      "x-sensitive": true
    },
    "POSTGRES_DB": {
      "type": "string",
      "minLength": 1
    },
    "DATABASE_URL": {
      "type": "string",
      "format": "postgresql-url",
      "x-sensitive": true
    },
    "JWT_SECRET": {
      "type": "string",
      "minLength": 32,
      "x-sensitive": true
    },
    "API_IMAGE": {
      "type": "string",
      "format": "image-reference"
    },
    "BASE_URL": {
      "type": "string",
      "format": "https-url"
    },
    "API_BASE_URL": {
      "type": "string",
      "format": "https-url"
    },
    "ALLOWED_ORIGINS": {
      "type": "string",
      "format": "csv-https-urls"
    }
  }
}
