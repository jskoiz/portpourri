{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "expo-web",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd mobile && NODE_OPTIONS='--no-experimental-detect-module' npx expo start --web --port $PORT"],
      "port": 8082,
      "autoPort": true
    },
    {
      "name": "backend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd backend && npx nest start --watch"],
      "port": 3010
    },
    {
      "name": "storybook-web",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd mobile && NODE_OPTIONS='--no-experimental-detect-module' npx storybook dev -p $PORT --no-open"],
      "port": 6006,
      "autoPort": true
    }
  ]
}
