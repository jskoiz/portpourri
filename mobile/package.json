    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "storybook": "^10.3.3",
    "typescript": "~5.9.2",
    "vite": "^8.0.3"
  },
  "private": true
}
