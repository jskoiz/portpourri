{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "storybook:start": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "npm run typecheck && npm run check:boundaries",
    "check:boundaries": "node ./scripts/check-screen-boundaries.js",
    "feature:new": "hygen feature new",
    "typecheck": "tsc --noEmit",
    "test": "node --max-old-space-size=8192 ./node_modules/jest/bin/jest.js --runInBand",
    "check": "npm run lint && npm run test"
  },
  "expo": {
    "install": {
      "exclude": [
        "@sentry/react-native"
      ]
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@lottiefiles/dotlottie-react": "^0.13.5",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-native-community/slider": "^5.0.1",
    "@react-navigation/bottom-tabs": "^7.8.7",
    "@react-navigation/native": "^7.1.22",
    "@react-navigation/native-stack": "^7.8.1",
    "@sentry/react-native": "^8.4.0",
    "@shopify/flash-list": "^2.0.2",
    "@tamagui/animations-react-native": "^2.0.0-rc.26",
    "@tamagui/config": "^2.0.0-rc.26",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.2",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "lottie-react-native": "~7.3.1",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.71.2",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.2",
    "react-native-deck-swiper": "^2.0.19",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1",
    "tamagui": "^2.0.0-rc.26",
    "zod": "^4.3.6",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@storybook/addon-ondevice-actions": "^10.2.3",
    "@storybook/addon-ondevice-controls": "^10.2.3",
    "@storybook/react-native": "^10.2.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "hygen": "^6.2.11",
    "jest": "^29.7.0",
