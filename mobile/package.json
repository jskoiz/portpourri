{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "storybook:start": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start -c",
    "storybook:web": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "npm run typecheck && npm run check:boundaries",
    "check:boundaries": "node ../scripts/check-repo-policies.mjs --scope mobile",
    "feature:new": "node ./scripts/scaffold-feature.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --max-old-space-size=8192 ./node_modules/jest/bin/jest.js --detectOpenHandles --forceExit",
    "check": "npm run lint && npm run test",
    "update:preview": "npx eas update --channel preview",
    "update:production": "npx eas update --channel production"
  },
  "expo": {
    "install": {
      "exclude": [
        "@sentry/react-native"
      ]
    }
  },
  "dependencies": {
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@lottiefiles/dotlottie-react": "^0.13.5",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-native-community/slider": "^5.0.1",
    "@react-navigation/bottom-tabs": "^7.8.7",
    "@react-navigation/native": "^7.1.22",
    "@react-navigation/native-stack": "^7.8.1",
    "@sentry/react-native": "^8.4.0",
    "@shopify/flash-list": "^2.0.2",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.2",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "lottie-react-native": "~7.3.1",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.71.2",
    "react-native": "0.81.5",
    "react-native-deck-swiper": "^2.0.19",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1",
    "socket.io-client": "^4.8.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@storybook/addon-ondevice-actions": "^10.2.3",
    "@storybook/addon-ondevice-controls": "^10.2.3",
    "@storybook/react-native": "^10.2.3",
    "@storybook/react-native-web-vite": "^10.3.3",
