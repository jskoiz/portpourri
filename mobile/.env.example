APP_ENV=development
EXPO_PUBLIC_API_URL=https://api.brdg.social
EXPO_PUBLIC_DEV_LAN_API_URL=http://192.168.1.10:3010
EXPO_PUBLIC_APP_NAME=BRDG
EXPO_PUBLIC_APP_SLUG=brdg
IOS_BUNDLE_IDENTIFIER=com.avmillabs.brdg
IOS_BUILD_NUMBER=1
ANDROID_PACKAGE=com.avmillabs.brdg
ANDROID_VERSION_CODE=1
# Optional: Sentry DSN for crash reporting (leave blank to disable).
EXPO_PUBLIC_SENTRY_DSN=
# Google OAuth Client ID for social login (iOS client ID from GCP console).
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
# Set to "true" to launch in Storybook mode instead of the main app.
# EXPO_PUBLIC_STORYBOOK_ENABLED=false
# Optional when using EAS Update / EAS Build with a linked project.
EAS_PROJECT_ID=
