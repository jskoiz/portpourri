# Copy to .env (do not commit .env)
DATABASE_URL="postgresql://brdg_user:brdg_password@localhost:5433/brdg_db"
JWT_SECRET="dev-secret-change-me"
PORT=3010
BASE_URL="http://localhost:3010"
API_BASE_URL="http://localhost:3010"
# NODE_ENV is set automatically by NestJS in most cases; override only when needed.
# NODE_ENV=development
# Comma-separated list of allowed CORS origins. Defaults to http://localhost:3000.
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Social Login (OAuth) ---
# Google: Create OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
# Apple: Create a Services ID at https://developer.apple.com/account/resources/identifiers
APPLE_CLIENT_ID=

# --- Sentry Error Tracking ---
# Create a NestJS project at https://sentry.io and paste the DSN here.
SENTRY_DSN=

# --- Cloudflare R2 Photo Storage ---
# Set STORAGE_PROVIDER=r2 to use R2 in production. Default is "local" (filesystem).
STORAGE_PROVIDER=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=brdg-photos
R2_PUBLIC_URL=
